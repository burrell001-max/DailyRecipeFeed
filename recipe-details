<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipe Details | DailyRecipeFeed</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: sans-serif; }
        body { background-color: #faf9f6; color: #222; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        .wrapper { width: 100%; max-width: 800px; background: white; border: 1px solid #e2e0d9; padding: 30px; margin-top: 20px; }
        .back-btn { display: inline-block; margin-bottom: 20px; color: #f05a28; font-weight: bold; text-decoration: none; }
        .recipe-title { font-size: 32px; margin-bottom: 10px; }
        .recipe-meta { color: #767676; text-transform: uppercase; font-size: 12px; font-weight: bold; margin-bottom: 20px; }
        .recipe-img { width: 100%; max-height: 450px; object-fit: cover; margin-bottom: 25px; }
        .recipe-desc { font-size: 18px; line-height: 1.6; color: #444; margin-bottom: 30px; }
        
        /* Google AdSense Layout Placeholders */
        .adsense-box {
            background: #f0ede6;
            border: 1px dashed #8e8c84;
            padding: 20px;
            text-align: center;
            color: #666;
            font-size: 12px;
            margin: 25px 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div class="wrapper">
        <a href="./index.html" class="back-btn">← Back to Recipes</a>
        
        <div class="adsense-box">[ Google AdSense - Top Banner Unit ]</div>

        <h1 id="display-title" class="recipe-title">Loading Recipe...</h1>
        <div id="display-meta" class="recipe-meta"></div>
        <img id="display-img" class="recipe-img" src="" alt="">
        <p id="display-desc" class="recipe-desc"></p>

        <div class="adsense-box">[ Google AdSense - In-Article Matching Unit ]</div>
    </div>

    <script src="./recipes.js"></script>
    <script>
        window.onload = function() {
            // Get the ID from the URL string
            const params = new URLSearchParams(window.location.search);
            const recipeId = params.get('id');

            // Locate matching item in the array
            const recipe = recipeCatalog.find(item => item.id === recipeId);

            if (recipe) {
                document.title = recipe.title + " | DailyRecipeFeed";
                document.getElementById('display-title').innerText = recipe.title;
                document.getElementById('display-meta').innerText = `${recipe.category} • ★★★★★ (${recipe.reviews} Reviews)`;
                document.getElementById('display-img').src = recipe.img;
                document.getElementById('display-img').alt = recipe.title;
                document.getElementById('display-desc').innerText = recipe.description;
            } else {
                document.getElementById('display-title').innerText = "Recipe Not Found";
                document.getElementById('display-desc').innerText = "The requested layout address could not be resolved or the recipe has been moved.";
            }
        }
    </script>
</body>
</html>
